{
  "name": "aiero-reactjs",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/prepare-amplify-outputs.mjs && node scripts/generate-route-snapshot.mjs && node scripts/generate-sitemap.mjs && tsc -b && vite build && vite build --ssr src/entry-server.tsx --outDir dist-server && node scripts/prerender-seo-pages.mjs && node scripts/validate-seo.mjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "seo:generate": "node scripts/generate-sitemap.mjs",
    "seo:indexnow": "node scripts/submit-indexnow.mjs --urls-from-sitemap --all-engines",
    "seo:indexnow:all": "node scripts/submit-indexnow.mjs --urls-from-sitemap --all-engines",
    "seo:indexnow:bing": "node scripts/submit-indexnow.mjs --urls-from-sitemap --engine=bing",
    "seo:indexnow:dry-run": "node scripts/submit-indexnow.mjs --urls-from-sitemap --all-engines --dry-run",
    "seo:prerender": "node scripts/prerender-seo-pages.mjs",
    "amplify:sandbox": "npx ampx sandbox",
    "amplify:generate-outputs": "npx ampx generate outputs",
    "amplify:pipeline-deploy": "npx ampx pipeline-deploy"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1033.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "aws-amplify": "^6.16.4",
    "gsap": "^3.14.2",
    "hover-effect": "^1.2.1",
    "imagesloaded": "^5.0.0",
    "isotope-layout": "^3.0.6",
    "lenis": "^1.3.18",
    "lightgallery": "^2.9.0",
    "odometer": "^0.4.8",
    "ogl": "^1.0.11",
    "rc-slider": "^11.1.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "sass": "^1.98.0",
    "split-type": "^0.3.4",
    "swiper": "^12.1.2"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.22.0",
    "@aws-amplify/backend-cli": "^1.8.2",
    "@eslint/js": "^9.39.4",
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "aws-cdk-lib": "^2.250.0",
    "constructs": "^10.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
